# API server settings (copy to backend/.env)
HOST="0.0.0.0"
PORT="3001"

# Optional HTTPS certificate paths (defaults to project certs/localhost-*.pem)
# SSL_KEY_PATH="C:\path\to\localhost-key.pem"
# SSL_CERT_PATH="C:\path\to\localhost-cert.pem"
# ALLOW_HTTP="true"

# Database connection: copy to backend/prisma/.env (do not duplicate DATABASE_URL in backend/.env)
# DATABASE_URL="sqlserver://localhost:1433;database=BookNest;integratedSecurity=true;encrypt=true;trustServerCertificate=true"
