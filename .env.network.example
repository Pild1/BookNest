# Copy to .env.network.local or set in PowerShell for LAN demos.

# Regenerate HTTPS cert when your LAN IP changes:
#   npm run certs:force

# Optional: force extra IP(s) into the dev certificate (comma-separated)
# BOOKNEST_LAN_IP=192.168.1.42

# Client machine: talk directly to the server API (no Vite proxy)
# VITE_API_URL=https://192.168.1.42:3001

# Server machine: Vite proxy target (default https://127.0.0.1:3001)
# VITE_API_PROXY_TARGET=https://127.0.0.1:3001
