{
  "name": "booknest-assignment-4-fullstack",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "certs": "node scripts/ensureDevCerts.mjs",
    "certs:force": "node scripts/ensureDevCerts.mjs --force",
    "network": "node scripts/printNetworkUrls.mjs",
    "predev": "node scripts/ensureDevCerts.mjs",
    "dev": "node scripts/printNetworkUrls.mjs && vite",
    "prebackend": "node scripts/ensureDevCerts.mjs",
    "backend": "node backend/src/server.js",
    "db:generate": "prisma generate --schema backend/prisma/schema.prisma",
    "db:migrate": "node backend/prisma/runMigrations.js",
    "db:seed": "node backend/prisma/seed.js",
    "backend:test": "node --test backend/tests/*.test.js",
    "build": "vite build",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@prisma/client": "^6.8.0",
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.16.0",
    "selfsigned": "^2.4.1",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.0",
    "@vitest/coverage-v8": "^3.0.0",
    "jsdom": "^25.0.0",
    "prisma": "^6.8.0",
    "vitest": "^3.0.0"
  }
}
